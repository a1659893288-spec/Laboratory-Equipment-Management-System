<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ShiyanshiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.ShiyanshiEntity" id="shiyanshiMap">
        <result property="shiyanshibianhao" column="shiyanshibianhao"/>
        <result property="shiyanshimingcheng" column="shiyanshimingcheng"/>
        <result property="shiyanshiguimo" column="shiyanshiguimo"/>
        <result property="shiyanshifenlei" column="shiyanshifenlei"/>
        <result property="shiyanshitupian" column="shiyanshitupian"/>
        <result property="shiyanshiweizhi" column="shiyanshiweizhi"/>
        <result property="shiyanshizhuangtai" column="shiyanshizhuangtai"/>
        <result property="shiyanshishebei" column="shiyanshishebei"/>
        <result property="keyueshijian" column="keyueshijian"/>
        <result property="shiyanshiqingkuang" column="shiyanshiqingkuang"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ShiyanshiVO" >
		SELECT * FROM shiyanshi  shiyanshi         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ShiyanshiVO" >
		SELECT  shiyanshi.* FROM shiyanshi  shiyanshi 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ShiyanshiView" >

		SELECT  shiyanshi.* FROM shiyanshi  shiyanshi 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ShiyanshiView" >
		SELECT * FROM shiyanshi  shiyanshi <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
